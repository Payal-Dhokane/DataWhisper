# Groq API Key (Get one at https://console.groq.com/)
GROQ_API_KEY=your_groq_api_key_here

# Cookie Secret Key — used to sign authentication session cookies.
# Generate a strong random value with:
#   python -c "import secrets; print(secrets.token_hex(32))"
# NEVER commit the real value to version control.
COOKIE_SECRET_KEY=your_generated_secret_key_here

# Optional: Ollama configuration (if running locally)
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3